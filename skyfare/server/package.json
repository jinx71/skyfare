    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.14.2",
    "helmet": "^6.0.1",
    "jsonwebtoken": "8.5.1",
    "mongoose": "^6.5.0",
    "morgan": "^1.10.0",
