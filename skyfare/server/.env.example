# ---- Core ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ---- Database ----
# Local MongoDB or a MongoDB Atlas connection string.
MONGO_URI=mongodb://localhost:27017/skyfare

# ---- Auth (reserved; SkyFare auth is optional) ----
JWT_SECRET=change_me

# ---- Amadeus Self-Service API ----
# Create free test credentials at https://developers.amadeus.com
# These live ONLY on the server and are never exposed to the React client.
# Leave these blank to run SkyFare in clearly-labelled MOCK mode (sample flights/airports)
# so the app is runnable without signing up. Fill them in for real flight data.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com
